// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
//  directUrl = env("DIRECT_URL")
  extensions = [uuid_ossp(map: "uuid-ossp")]
}


// 1. Users
model User {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  fullName     String   @map("full_name") @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash")
  role         Role
  country      String   @db.Char(2)
  baseCurrency String   @map("base_currency") @db.Char(3)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  products    Product[]
  cartItems   CartItem[]
  orders      Order[]
  orderItems  OrderItem[]

  @@index([role])
  @@map("users")
}

enum Role {
  merchant
  customer
}

// 2. Products
model Product {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  merchantId  String   @map("merchant_id") @db.Uuid
  merchant    User     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  name        String   @db.VarChar(255)
  description String?
  price       Decimal  @db.Decimal(12, 2)
  currency    String   @db.Char(3)
  category    String?  @db.VarChar(100)
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@index([merchantId])
  @@index([category]) // Note: Prisma handles standard indices; complex partial indices are often done via raw SQL in migrations
  @@map("products")
}

// 3. Cart Items
model CartItem {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([userId, productId], name: "unique_user_product")
  @@index([userId])
  @@map("cart_items")
}

// 4. Orders
model Order {
  id                  String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customerId          String      @map("customer_id") @db.Uuid
  customer            User        @relation(fields: [customerId], references: [id])
  status              OrderStatus @default(pending)
  customerCurrency    String      @map("customer_currency") @db.Char(3)
  customerTotal       Decimal     @map("customer_total") @db.Decimal(12, 2)
  exchangeRateApplied Decimal     @map("exchange_rate_applied") @db.Decimal(18, 6)
  createdAt           DateTime    @default(now()) @map("created_at") @db.Timestamptz

  orderItems OrderItem[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}

enum OrderStatus {
  pending
  completed
  review_required
}

// 5. Order Items
model OrderItem {
  id                        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderId                   String   @map("order_id") @db.Uuid
  productId                 String   @map("product_id") @db.Uuid
  merchantId                String   @map("merchant_id") @db.Uuid
  order                     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product                   Product  @relation(fields: [productId], references: [id])
  merchant                  User     @relation(fields: [merchantId], references: [id])
  quantity                  Int
  unitPriceMerchantCurrency Decimal  @map("unit_price_merchant_currency") @db.Decimal(12, 2)
  merchantCurrency          String   @map("merchant_currency") @db.Char(3)
  merchantPayoutAmount      Decimal  @map("merchant_payout_amount") @db.Decimal(12, 2)
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([orderId])
  @@index([merchantId])
  @@map("order_items")
}

// 6. Rate Cache
model RateCache {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  baseCurrency String   @map("base_currency") @db.Char(3)
  rates        Json
  fetchedAt    DateTime @default(now()) @map("fetched_at") @db.Timestamptz
  isStale      Boolean  @default(false) @map("is_stale")

  @@index([baseCurrency, fetchedAt(sort: Desc)])
  @@map("rate_cache")
}
